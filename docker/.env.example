# MORM federated node — env config (Phase 30b).
# Copy this file to `.env` next to morm-node.docker-compose.yml.
# All values have safe defaults except TREASURY for the L1 service.

# ---- L1 chain ----
# Required: the chain's treasury address. Use the m0r-prefix address you
# generated alongside your producer seed (see ./init.sh).
# Example: m0r3or65m6jbnlb6fnd2nvylah23vo54dky
TREASURY=

# Optional: explicitly override which peers we gossip to. Leave empty to
# fall back to the baked-in seeds.json (Phase 30c). Comma-separated URLs.
PEERS=

# Phase 24a opt-in: parallel sealing instead of slot election.
DAG_MODE=0

# Phase 25a opt-in: QUIC gossip transport (fall back to HTTP otherwise).
QUIC=0

# Phase 26e: 0 = no genesis lockdown (anyone can produce). Default 100
# is recommended for new networks where the treasury is the only initial
# producer (raise this for stricter eclipse defense).
GENESIS_LOCKDOWN_HEIGHT=0

# Run as a passive importer (no block production). Useful for relays.
NO_PRODUCE=0

# If your node has a public-facing URL, set it here so the seed-list
# discovery loop can avoid pointing peers back at us as a peer.
L1_PUBLIC_URL=

# ---- Browser gateway ----
# DEV_MODE=1 enables /api/dev/* routes (XOR share fetch + bootstrap key
# registration). LOCAL ONLY — never enable in production.
DEV_MODE=1

# Strict CSRF/CORS. Comma-separated browser origins. Leave empty for
# legacy "*"-CORS dev mode.
ALLOWED_ORIGINS=

# Phase 25Vc: opt-in CDN edge prefix that the gateway rewrites .m3u8
# segment URIs to. Leave empty for origin-only mode (3原則 default).
CDN_BASE_URL=

# Treasury seed for HLS register-content hook + bridge mint relay. Bind
# this file 0o600 from the host (set TREASURY_KEYFILE_HOST). The gateway
# refuses any other mode.
TREASURY_SEED_FILE=
TREASURY_KEYFILE_HOST=

# ---- Bridge / /swap (Phase 28a/28b). All optional. Leave empty to hide
#      the bridge UI and disable the /api/morm/bridge endpoint. ----
BRIDGE_ADDR=
EVM_RPC=
EVM_CHAIN_ID=
ERC20_BRIDGE_ADDR=
USDC_ADDR=

# ---- TURN ----
TURN_URL=
TURN_SECRET=

# ---- Edge ----
EDGE_ROLE=mirror
EDGE_NODE_ID=edge-0
EDGE_PEERS=http://l1:8900

# ---- Images: default to the public ghcr release. Override to "morm-*:dev"
#      for local-build mode (`docker compose build`). ----
L1_IMAGE=ghcr.io/kemonos0424/morm-l1:latest
GATEWAY_IMAGE=ghcr.io/kemonos0424/morm-gateway:latest
EDGE_IMAGE=ghcr.io/kemonos0424/morm-edge:latest

# ---- Port mappings (host side) ----
L1_PORT=8900
GATEWAY_PORT=8801
EDGE_PORT=8787

# ---- Phase 30f tunnel (optional) ----
CLOUDFLARED_TOKEN=
